# ─── Environment ──────────────────────────────────────────────────────────────
# Controls environment-specific behavior (e.g. SSL on DB connections)
# Options: dev | staging | prod
ENVIRONMENT=dev

# ─── Database ────────────────────────────────────────────────────────────────
# Pooled connection (port 6543) — used by the running app via Supavisor
# Locally: run `supabase start` then `supabase status` to get the DB URL
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:54322/postgres

# Direct connection (port 5432) — used by Alembic for migrations
# Locally: same as DATABASE_URL (Supabase CLI exposes Postgres on 54322 directly)
DATABASE_URL_DIRECT=postgresql+asyncpg://postgres:postgres@localhost:54322/postgres

# ─── Redis ───────────────────────────────────────────────────────────────────
# Used by ARQ for background job queuing
# Locally: run `brew services start redis`
REDIS_URL=redis://localhost:6379

# ─── Supabase ────────────────────────────────────────────────────────────────
# Supabase API URL — used to fetch JWKS public keys for JWT verification
# Locally: http://127.0.0.1:54321 (default from `supabase start`)
# Production: Supabase dashboard → Project Settings → API → Project URL
SUPABASE_URL=http://127.0.0.1:54321

# Supabase anon (publishable) key — sent as the `apikey` header on GoTrue REST
# calls (e.g. phone verification). Public; same value the iOS app embeds.
# Locally: from `supabase status` → Publishable key.
# Staging/Prod: Supabase dashboard → Project Settings → API → Project API keys.
SUPABASE_ANON_KEY=

# ─── API Key Gate ────────────────────────────────────────────────────────
# Static key baked into the iOS app — lightweight gate to prevent random API
# discovery. Not auth (JWT handles identity).
# Local dev: leave empty to disable the check entirely (middleware becomes a no-op)
# Staging/Prod: required — set to a strong random value: openssl rand -hex 32
API_KEY=

# ─── Alpaca ──────────────────────────────────────────────────────────────────
# Broker API keys — use sandbox keys for local dev
# Get from: https://broker-app.alpaca.markets → sandbox environment
ALPACA_API_KEY=your-alpaca-sandbox-api-key
ALPACA_SECRET_KEY=your-alpaca-sandbox-secret-key

# ─── Sentry ──────────────────────────────────────────────────────────────────
# Error monitoring and performance tracking
# Optional: leave blank for local dev (Sentry will not initialize)
SENTRY_DSN=

# ─── Plaid ───────────────────────────────────────────────────────────────────
# Get from: https://dashboard.plaid.com → Team Settings → Keys
PLAID_CLIENT_ID=your-plaid-client-id
PLAID_SECRET=your-plaid-sandbox-secret
# Options: sandbox | development | production
PLAID_ENV=sandbox
# Fernet key(s) for encrypting Plaid access tokens at rest. Generate with:
#   uv run python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# For rotation, provide a comma-separated list — the first key is used for
# encryption; all keys are tried on decrypt.
PLAID_FERNET_KEY=your-plaid-fernet-key
