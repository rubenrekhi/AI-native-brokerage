    "%@ (%@)" : {
      "comment" : "A sublabel within a holding row that shows the unrealized profit or loss (P/L) and its percentage. Both values are suffixed with their respective currency symbols.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "%1$@ (%2$@)"
          }
        }
      }
    },
    "%@ %@" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "%1$@ %2$@"
          }
        }
      }
    },
