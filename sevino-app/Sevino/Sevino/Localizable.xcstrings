      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "in purchasing power lost every year when $10,000 sits in a savings account. Invested, it could be growing."
          }
        }
      }
    },
    "onboarding.reflection_b_stat_number" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "$200–$400"
          }
        }
      }
    },
    "onboarding.reflection_c_body1" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "There are over 4,000 stocks on the market, thousands of ETFs, and a million opinions online. It's a lot."
          }
        }
      }
    },
    "onboarding.reflection_c_body2" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "That's exactly why you won't be doing this alone."
          }
        }
      }
    },
    "onboarding.reflection_c_heading" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Totally fair, %@."
          }
        }
      }
    },
    "onboarding.reflection_c_source" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Source: Gallup/FINRA Foundation, 2022"
          }
        }
      }
    },
    "onboarding.reflection_c_stat_desc" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "of non-investors say they feel overwhelmed by the process. The problem isn't you — it's that nobody made this simple enough."
          }
        }
      }
    },
    "onboarding.reflection_c_stat_number" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "44%"
          }
        }
      }
    },
    "onboarding.reflection_d_body1" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "You don't need the basics explained. You need an AI that can pull real data, analyze your portfolio, and help you move faster."
          }
        }
      }
    },
    "onboarding.reflection_d_body2" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "That's what this is."
          }
        }
      }
    },
    "onboarding.reflection_d_heading" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Respect."
